# Identificação do cliente (aparece nos e-mails e no nome do arquivo)
REPORT_CLIENT_NAME=Nome do Condomínio

# Credenciais Condfy (login web da licença)
CONDFY_EMAIL=
CONDFY_PASSWORD=
CONDFY_LICENSE_ID=

# Bravas — array JSON com 1+ controladores Módulo Acesso PRD0028
# Cada item: {nome, host, uiPort, apiPort}
BRAVAS_CONTROLLERS=[{"nome":"A","host":"x.x.x.x","uiPort":8787,"apiPort":8090},{"nome":"B","host":"x.x.x.x","uiPort":8889,"apiPort":8091}]
BRAVAS_USER=
BRAVAS_PASSWORD=

# Resend — envio de e-mail
RESEND_API_KEY=re_xxx
REPORT_FROM=Nome Remetente <noreply@seu-dominio.com>
REPORT_RECIPIENTS=destinatario1@dominio.com,destinatario2@dominio.com
